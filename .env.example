# Postgres (e.g. Neon)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Site gate — shared with family
SITE_PASSPHRASE=change-me-long-random

# Admin dashboard (/admin)
ADMIN_SECRET=change-me-different-long-random

# Sign cookies — each value MUST be at least 16 characters (use long random strings).
SESSION_SECRET=replace_with_at_least_sixteen_chars
GUEST_JWT_SECRET=another_long_random_secret_min_16

# Stay window (CDT property dates; Aug 1 is exclusive)
STAY_YEAR=2026
STAY_MONTH_START=7
STAY_DAY_START=3
STAY_MONTH_END_EXCLUSIVE=8
STAY_DAY_END_EXCLUSIVE=1
TIMEZONE=America/Chicago

# Optional: booking rules — defaults match sensible first-round rollout
MAX_STAY_NIGHTS=7
# Calendar blackout (inclusive, local stay year) — no guest bookings on these days
BLACKOUT_MONTH=7
BLACKOUT_DAY_START=3
BLACKOUT_DAY_END=5

# Optional: public URL for magic links in email
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email via Resend — see README "Guest email (Resend)": API key + verified domain + from-address on that domain.
# Without these, bookings still save; the API returns devMagicLink instead of sending mail.
RESEND_API_KEY=
# Production example: RESEND_FROM="any label <bookings@yourdomain.com>" — the visible sender name is set in src/lib/mail.ts
RESEND_FROM="Beach stay <onboarding@resend.dev>"

# Optional: override the built-in address from src/lib/property-info.ts (Trip info page + emails)
BOOKING_PROPERTY_ADDRESS=

# Optional: allow /api/calendar.ics?feed=THIS without passphrase (for Google subscribe)
CALENDAR_FEED_TOKEN=
